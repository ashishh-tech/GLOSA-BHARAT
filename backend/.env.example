# ─── GLOSA-BHARAT Backend Environment Variables ─────────────────────────────
# Copy this file to .env and fill in your values

# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/glosa-bharat?retryWrites=true&w=majority

# Server port (Cloud Run will override this automatically)
PORT=3000

# Allowed frontend origin
FRONTEND_URL=https://glosa-frontend.pages.dev

# AI Service URL (update after deploying glosa-ai to Cloud Run)
AI_SERVICE_URL=https://glosa-ai-xxxx-el.a.run.app

# Node environment
NODE_ENV=production
