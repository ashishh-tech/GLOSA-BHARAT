# Dependencies
node_modules/
.venv/
venv/
env/

# Build artifacts
dist/
build/

# Environment variables
.env
.env.local
.env.production

# Python cache
__pycache__/
*.py[cod]
*$py.class

# IDE / Editor
.vscode/
.idea/
*.swp
*.swo

# OS generated
.DS_Store
Thumbs.db
desktop.ini

# Cloudflare / Tunnel
.wrangler/
cloudflared.exe
tunnel.*

# Logs
*.log
*.err
*.out
